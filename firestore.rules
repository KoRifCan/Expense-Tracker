rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Users collection
    match /users/{uid} {
      // Anyone can read their own data; admins can read all
      allow read: if isOwner(uid) || isAdmin();

      // Create: only during registration (must be self)
      allow create: if isOwner(uid);

      // Update: self can update profile but NOT role/disabled; admin can update anything
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role && request.resource.data.disabled == resource.data.disabled) || isAdmin();

      // Delete: admin only, or self (user deleting own account)
      allow delete: if isAdmin() || isOwner(uid);

      // Subcollections (transactions)
      match /transactions/{txnId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }
  }
}
